# Snowflake
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
# Account identifier for drivers (NOT the URL). From Snowflake: Admin > Accounts, or JDBC string.
# Use the full form if you get 404 on login, e.g. xy12345.us-east-1.aws or MYORG-MYACCOUNT
SNOWFLAKE_ACCOUNT=
# Optional if account is only a short locator (404 often fixed by full account or these two):
# SNOWFLAKE_REGION=us-east-1
# SNOWFLAKE_CLOUD=aws
# Optional PrivateLink / proxy override:
# SNOWFLAKE_HOST=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=TARIFFIQ
SNOWFLAKE_SCHEMA=RAW
 
# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

#AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
# Federal Register XML is stored at raw/federal-register/<year>/<mm>/<document_number>.xml
S3_BUCKET=tariff-iq-federal-registry-bucket

# Trial Airflow FR pipeline: cap fetch / parse / chunk / HTS to N docs (omit or 0 = unlimited)
# FR_PIPELINE_MAX_DOCS=10

# Census Bureau
CENSUS_API_KEY=
 
# Redis (inside Docker, do not change)
REDIS_URL=redis://redis:6379
 
# ChromaDB (inside Docker, do not change)
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
 
# Airflow
AIRFLOW_SECRET_KEY=changeme_use_a_real_secret
 
# FastAPI URL (used by Streamlit inside Docker, do not change)
FASTAPI_URL=http://fastapi:8001

